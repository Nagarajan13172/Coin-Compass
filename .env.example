# Server
PORT=4000
MONGO_URI=mongodb://localhost:27017/money-tracker
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Public base URLs. APP_URL is the browser-facing origin and is used for OAuth
# redirects so the SPA and auth cookies stay on the same host.
# SERVER_URL is the direct backend origin if you ever call the API without a proxy.
SERVER_URL=http://localhost:4000
APP_URL=http://localhost:5173

# Auth
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_COOKIE_NAME=mt_session

# OAuth providers — leave blank to hide that provider's button.
# Redirect URI to register for each: ${APP_URL}/api/auth/oauth/<provider>/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Apple: APPLE_CLIENT_ID is the Service ID; APPLE_PRIVATE_KEY is the .p8 contents.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
