{
  "name": "coincompass-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "seed": "tsx src/seed/index.ts",
    "seed:all": "tsx src/scripts/seedAll.ts",
    "migrate:user": "tsx src/scripts/migrateToUser.ts",
    "migrate:credits": "tsx src/scripts/migrateCreditsToTransfers.ts",
    "backfill:credit-categories": "tsx src/scripts/backfillCreditCategories.ts",
    "backfill:templates": "tsx src/scripts/backfillTemplates.ts",
    "backfill:metals": "tsx src/scripts/backfillMetalHistory.ts",
    "backfill:metals:est": "tsx src/scripts/backfillMetalHistoryEstimated.ts",
    "build": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "arctic": "^3.7.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "zod": "^3.24.1"
