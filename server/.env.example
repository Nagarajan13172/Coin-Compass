# ---- Core ----
PORT=4000
MONGO_URI=mongodb://localhost:27017/money-tracker
NODE_ENV=development

# Public base URLs. In local dev the client (Vite) runs on 5173 and proxies /api
# to the server on 4000.
CLIENT_URL=http://localhost:5173
# APP_URL is the browser-facing origin. OAuth callbacks and verification links
# use this origin so the whole auth flow stays on the same host as the SPA.
# SERVER_URL is the direct backend origin if you ever call the API without Vite.
SERVER_URL=http://localhost:4000
APP_URL=http://localhost:5173
# Optional: force OAuth providers to call back to a specific origin. If unset,
# the app can infer the origin from the incoming request or fall back to SERVER_URL.
OAUTH_REDIRECT_BASE_URL=http://localhost:4000

# ---- Session ----
# Generate a strong secret, e.g.  openssl rand -base64 48
AUTH_JWT_SECRET=dev-insecure-secret-change-me
AUTH_COOKIE_NAME=mt_session
# How long an email-verification link stays valid.
AUTH_EMAIL_TOKEN_TTL_HOURS=24

# ---- Email (verification links) ----
# If these are left blank the server won't send real email — it prints the
# verification link to the console instead, so signup still works in local dev.
# For Gmail: create an "App password" (Google Account > Security > App passwords)
# and use it as SMTP_PASS with SMTP_HOST=smtp.gmail.com, SMTP_PORT=587.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # true only for port 465
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Money Tracker <no-reply@moneytracker.local>

# ---- OAuth providers ----
# A provider's button appears on the login/signup pages ONLY when both its id and
# secret are set. Redirect/callback URL for each is:
#   {OAUTH_REDIRECT_BASE_URL or inferred origin}/api/auth/oauth/{provider}/callback
# See docs/auth-setup.md for step-by-step registration instructions.

# Google  (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub  (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft / Entra ID  (https://portal.azure.com > App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common      # or your tenant id; "common" allows any account

# Apple  (https://developer.apple.com > Certificates, Identifiers & Profiles)
APPLE_CLIENT_ID=             # the Services ID, e.g. com.yourapp.web
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=           # contents of the .p8 key (newlines as \n)
