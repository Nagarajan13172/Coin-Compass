# Frontend (Vite) environment — template. Copy to .env and adjust as needed:
#   cp .env.example .env
#
# Only VITE_-prefixed variables are exposed to client code (import.meta.env).
# Never put secrets here — anything in the frontend bundle is publicly readable.

# Base URL the browser uses for API requests.
# Default "/api" routes through the Vite dev proxy (see VITE_API_PROXY).
# Set to a full URL (e.g. https://api.example.com) for a separately-hosted API.
VITE_API_BASE_URL=/api

# Dev only: the backend the Vite dev server proxies "/api" to.
VITE_API_PROXY=http://localhost:4000
